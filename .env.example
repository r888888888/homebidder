# Backend
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ENABLE_PERMIT_LLM=0            # set to 1 to use Anthropic for permit summaries/impact labels
DATABASE_URL=sqlite+aiosqlite:///./homebidder.db
ALLOWED_ORIGINS=http://localhost:3000
LOG_FILE=homebidder.log          # log file path (relative to backend/)

# External APIs (all free tiers)
# Sign up at rentcast.io/api
RENTCAST_API_KEY=your_rentcast_api_key_here
RENTCAST_SQFT_FALLBACK=1   # set to 0 in development to skip sqft RentCast lookups for comps
# Sign up at api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here
# Sign up at api.bart.gov/api/register.aspx (Phase 8 only)
BART_API_KEY=your_bart_api_key_here
# Sign up at fred.stlouisfed.org/docs/api/api_key.html (Phase 8 only)
FRED_API_KEY=your_fred_api_key_here

# Frontend
VITE_API_URL=http://localhost:8000
