# ============================================================
# HomeBidder — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ----------------------------------------------------------------
# Required
# ----------------------------------------------------------------

# Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_long_random_secret_here

# ----------------------------------------------------------------
# Database
# ----------------------------------------------------------------

# SQLite (default) or any SQLAlchemy-compatible URL
DATABASE_URL=sqlite+aiosqlite:///./homebidder.db

# ----------------------------------------------------------------
# Server / CORS
# ----------------------------------------------------------------

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Log file path (relative to backend/)
LOG_FILE=homebidder.log

# ----------------------------------------------------------------
# External data APIs  (all optional — features degrade gracefully)
# ----------------------------------------------------------------

# Census ACS data — sign up at api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# FRED mortgage rates — sign up at fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BART real-time departures — sign up at api.bart.gov/api/register.aspx
BART_API_KEY=your_bart_api_key_here

# SpotCrime crime data (used for non-SF Bay Area cities)
# Sign up at spotcrime.com/api
SPOTCRIME_API_KEY=your_spotcrime_api_key_here

# RentCast AVM — free tier: 50 calls/month, no credit card required
# Sign up at app.rentcast.io/app/api-access
RENTCAST_API_KEY=

# ----------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANALYSES_PER_DAY=5          # legacy anonymous daily limit (kept for backwards compat)
RATE_LIMIT_AUTHENTICATED_PER_DAY=20   # legacy authenticated daily limit (kept for backwards compat)
# Monthly limits per subscription tier (new system)
RATE_LIMIT_ANONYMOUS_PER_MONTH=3
RATE_LIMIT_BUYER_PER_MONTH=5
RATE_LIMIT_INVESTOR_PER_MONTH=30
RATE_LIMIT_AGENT_PER_MONTH=100

# LLM-assisted property description analysis (set to 1 to enable)
ENABLE_DESCRIPTION_LLM=0
DESCRIPTION_LLM_MODEL=claude-sonnet-4-6

# LLM-assisted permit summaries and impact labels (set to 1 to enable)
ENABLE_PERMIT_LLM=0
PERMIT_LLM_MODEL=claude-sonnet-4-6

# RentCast AVM blend: adds 15% AVM weight to comp-based fair value
# Requires both ENABLE_RENTCAST_AVM=1 AND a valid RENTCAST_API_KEY
ENABLE_RENTCAST_AVM=0

# Model used for renovation cost estimates
RENOVATION_LLM_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------
# Google OAuth  (optional — leave blank to disable "Sign in with Google")
# ----------------------------------------------------------------

# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/callback/google

# ----------------------------------------------------------------
# Apple Sign In  (optional — leave blank to disable "Sign in with Apple")
# ----------------------------------------------------------------

# Set up at developer.apple.com → Certificates, Identifiers & Profiles:
#   1. Register an App ID with "Sign in with Apple" capability
#   2. Create a Services ID (APPLE_CLIENT_ID) and register the redirect URI
#   3. Create a Sign in with Apple private key — download the .p8 file
#      and paste its contents here with literal \n for newlines, e.g.:
#      APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URL=http://localhost:3000/auth/callback/apple

# ----------------------------------------------------------------
# Admin portal  (optional — leave blank to disable /admin)
# ----------------------------------------------------------------

# HTTP Basic Auth credentials for the admin portal at /admin
# Generate a strong password: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ----------------------------------------------------------------
# Stripe  (optional — leave blank to disable payment features)
# ----------------------------------------------------------------

# Get keys at dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get webhook secret from: stripe listen --forward-to localhost:8000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products + prices at dashboard.stripe.com → Product catalog
STRIPE_INVESTOR_PRICE_ID=price_...    # $10/month — Investor tier
STRIPE_AGENT_PRICE_ID=price_...       # $30/month — Agent tier

# ----------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------

VITE_API_URL=http://localhost:8000
